<launch>
  <!-- Mode and basic args -->
  <arg name="sim"           default="false"/>                 <!-- true for simulation -->
  <arg name="map"           default="$(find navigation_pkg)/maps/home.yaml"/>
  <arg name="base_frame"    default="base_link"/>             <!-- base_link (real), base_footprint (sim) -->
  <arg name="odom_frame"    default="odom"/>
  <arg name="map_frame"     default="map"/>
  <arg name="scan_topic"    default="/scan"/>
  <arg name="start_rplidar" default="true"/>                  <!-- only start LiDAR on real -->

  <!-- Load naming contract for visibility in parameter tree -->
  <group unless="$(arg sim)">
    <rosparam file="$(find navigation_pkg)/config/nav_contract_real.yaml" command="load"/>
  </group>
  <group if="$(arg sim)">
    <rosparam file="$(find navigation_pkg)/config/nav_contract_sim.yaml" command="load"/>
    <param name="use_sim_time" value="true"/>
  </group>

  <!-- Robot state publisher (remove if another bringup already runs it) -->
  <node pkg="robot_state_publisher" type="robot_state_publisher" name="robot_state_publisher" output="screen">
    <param name="publish_frequency" value="50.0"/>
  </node>

  <!-- Real robot LiDAR (skip in sim) -->
  <group unless="$(arg sim)">
    <group if="$(arg start_rplidar)">
      <node pkg="rplidar_ros" type="rplidarNode" name="rplidar" output="screen">
        <param name="serial_port" value="/dev/ttyUSB0"/>       <!-- adjust if different -->
        <param name="serial_baudrate" value="115200"/>
        <param name="frame_id" value="laser"/>                 <!-- set to your actual laser frame -->
        <param name="angle_compensate" value="true"/>
      </node>
    </group>
  </group>

  <!-- Map server (loads saved map) -->
  <node pkg="map_server" type="map_server" name="map_server" args="$(arg map)"/>

  <!-- AMCL (localization) -->
  <node pkg="amcl" type="amcl" name="amcl" output="screen">
    <rosparam file="$(find navigation_pkg)/config/amcl.yaml" command="load"/>
    <param name="base_frame_id"   value="$(arg base_frame)"/>
    <param name="odom_frame_id"   value="$(arg odom_frame)"/>
    <param name="global_frame_id" value="$(arg map_frame)"/>
    <param name="scan_topic"      value="$(arg scan_topic)"/>
  </node>
</launch>
